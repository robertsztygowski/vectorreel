{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://mdreel.com/schemas/upload-created.schema.json",
  "title": "POST /uploads response (201)",
  "description": "Frozen 2026-07-16 (Phase 2.5). ARCHITECTURE.md §5.",
  "type": "object",
  "required": ["uploadId", "uploadUrl"],
  "additionalProperties": false,
  "properties": {
    "uploadId": { "type": "string", "minLength": 1 },
    "uploadUrl": {
      "description": "GCS signed resumable-upload URL; max size per plan.",
      "type": "string",
      "format": "uri"
    }
  }
}
