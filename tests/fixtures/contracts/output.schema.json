{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://mdreel.com/schemas/output.schema.json",
  "title": "mdreel output document (GET /jobs/{id}/output.json)",
  "description": "The structured form of the Markdown output contract. Normative for output.json; the Markdown form's grammar is ARCHITECTURE.md §4 with web/lib/outputDocument.ts as the executable reference. Frozen 2026-07-16 (Phase 2.5).",
  "type": "object",
  "required": ["frontmatter", "sections", "provenance"],
  "additionalProperties": false,
  "properties": {
    "frontmatter": { "$ref": "#/$defs/frontmatter" },
    "sections": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/section" }
    },
    "provenance": {
      "description": "Markdown body of the final '## Source & licence' section: attribution + licence for gallery outputs, the source-deletion/retention statement for private uploads.",
      "type": "string",
      "minLength": 1
    }
  },
  "$defs": {
    "timestamp": {
      "type": "string",
      "pattern": "^[0-9]{2}:[0-5][0-9]:[0-5][0-9]$"
    },
    "frontmatter": {
      "type": "object",
      "required": ["title", "source", "duration", "language", "processed_at", "generator", "summary", "tags"],
      "additionalProperties": false,
      "properties": {
        "title": { "type": "string", "minLength": 1 },
        "source": {
          "description": "Original upload filename (private path) or canonical source URL (internal ingest).",
          "type": "string",
          "minLength": 1
        },
        "duration": { "$ref": "#/$defs/timestamp" },
        "language": { "type": "string", "pattern": "^[a-z]{2}(-[A-Za-z]{2,4})?$" },
        "processed_at": {
          "description": "UTC ISO-8601; fractional seconds optional.",
          "type": "string",
          "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}T[0-9]{2}:[0-9]{2}:[0-9]{2}(\\.[0-9]{1,3})?Z$"
        },
        "generator": {
          "description": "mdreel@<version>. Committed fixtures use the reserved version 0.0.0-fixture.",
          "type": "string",
          "pattern": "^mdreel@[0-9A-Za-z.+-]+$"
        },
        "summary": { "type": "string", "minLength": 1 },
        "tags": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string", "pattern": "^[a-z0-9][a-z0-9 -]*$" }
        }
      }
    },
    "section": {
      "type": "object",
      "required": ["timestamp", "heading", "blocks"],
      "additionalProperties": false,
      "properties": {
        "timestamp": { "$ref": "#/$defs/timestamp" },
        "heading": { "type": "string", "minLength": 1 },
        "blocks": {
          "description": "1-3 blocks, each label at most once, in the order spoken, on_screen, visual.",
          "type": "array",
          "minItems": 1,
          "maxItems": 3,
          "items": { "$ref": "#/$defs/block" }
        }
      }
    },
    "block": {
      "type": "object",
      "required": ["label", "text"],
      "additionalProperties": false,
      "properties": {
        "label": { "enum": ["spoken", "on_screen", "visual"] },
        "text": {
          "description": "Multi-line text uses \\n: dialogue turns for spoken, one verbatim capture per line for on_screen. Never blank lines or carriage returns.",
          "type": "string",
          "minLength": 1
        }
      }
    }
  }
}
