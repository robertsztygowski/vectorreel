{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://mdreel.com/schemas/job-list.schema.json",
  "title": "GET /jobs response (200)",
  "description": "Frozen 2026-07-16 (Phase 2.5). ARCHITECTURE.md §5 — the authenticated panel's job list. Newest first; pagination is a Phase 3 concern and will be additive (query params + a nextCursor field).",
  "type": "object",
  "required": ["jobs"],
  "additionalProperties": false,
  "properties": {
    "jobs": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["jobId", "status", "progress", "source", "created_at"],
        "additionalProperties": false,
        "properties": {
          "jobId": { "type": "string", "minLength": 1 },
          "status": { "enum": ["queued", "processing", "done", "failed"] },
          "stage": { "enum": ["A", "B", "C", "D"] },
          "progress": { "type": "number", "minimum": 0, "maximum": 100 },
          "source": {
            "description": "Original upload filename — same semantics as the output document's frontmatter.source.",
            "type": "string",
            "minLength": 1
          },
          "duration_sec": { "type": "number", "minimum": 0 },
          "created_at": {
            "type": "string",
            "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}T[0-9]{2}:[0-9]{2}:[0-9]{2}(\\.[0-9]{1,3})?Z$"
          },
          "finished_at": {
            "type": "string",
            "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}T[0-9]{2}:[0-9]{2}:[0-9]{2}(\\.[0-9]{1,3})?Z$"
          }
        }
      }
    }
  }
}
