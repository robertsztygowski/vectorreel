{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.Hosting.Lifetime": "Information"
    }
  },
  "YouTubeGalleryRunner": {
    "Enabled": false,
    "OutputBucket": "outputs-eu",
    "OutputPrefix": "gallery",
    "SegmentLength": "00:10:00",
    "SegmentOverlap": "00:00:20",
    "StageB": {
      "MaxOutputTokens": 12000,
      "ThinkingBudget": 4096,
      "TimeoutSeconds": 90
    },
    "Videos": []
  }
}
