# Style + analyzer configuration. With EnforceCodeStyleInBuild + TreatWarningsAsErrors
# (Directory.Build.props), severity=warning rules below FAIL THE BUILD.
# To silence a noisy rule: downgrade it here with a comment saying why — never
# loosen the global switches.
root = true

[*]
charset = utf-8
insert_final_newline = true
trim_trailing_whitespace = true
indent_style = space

[*.{cs,csx}]
indent_size = 4

[*.{json,yml,yaml,tf,tfvars,props,csproj,sln,editorconfig}]
indent_size = 2

[*.md]
trim_trailing_whitespace = false

[*.cs]
# --- Usings ---
dotnet_sort_system_directives_first = true
csharp_using_directive_placement = outside_namespace:warning
dotnet_diagnostic.IDE0005.severity = warning        # remove unused usings

# --- Namespaces & types ---
csharp_style_namespace_declarations = file_scoped:warning
csharp_style_prefer_primary_constructors = true:suggestion
dotnet_style_require_accessibility_modifiers = for_non_interface_members:warning

# --- var ---
csharp_style_var_for_built_in_types = true:suggestion
csharp_style_var_when_type_is_apparent = true:suggestion
csharp_style_var_elsewhere = true:suggestion

# --- Expression preferences ---
csharp_style_expression_bodied_methods = when_on_single_line:suggestion
csharp_style_expression_bodied_properties = true:suggestion
dotnet_style_object_initializer = true:suggestion
dotnet_style_collection_initializer = true:suggestion
csharp_style_prefer_switch_expression = true:suggestion
dotnet_style_prefer_conditional_expression_over_return = false

# --- Nullability / correctness ---
dotnet_diagnostic.CA2007.severity = none            # ConfigureAwait(false): irrelevant in ASP.NET Core (no SyncContext)
dotnet_diagnostic.CA1848.severity = none            # LoggerMessage delegates: premature for MVP; revisit if logging is hot
# CA1711 forbids a "Queue" suffix on a type name. ITaskQueue is one of the four provider seams named
# in CLAUDE.md and DEVELOPMENT.md §2 — the docs own that name, and renaming the code to satisfy an
# analyzer would just put the two out of sync.
dotnet_diagnostic.CA1711.severity = none

# --- Naming: standard .NET conventions ---
dotnet_naming_rule.interfaces_begin_with_i.symbols = interface_symbols
dotnet_naming_rule.interfaces_begin_with_i.style = prefix_i
dotnet_naming_rule.interfaces_begin_with_i.severity = warning
dotnet_naming_symbols.interface_symbols.applicable_kinds = interface
dotnet_naming_style.prefix_i.capitalization = pascal_case
dotnet_naming_style.prefix_i.required_prefix = I

dotnet_naming_rule.private_fields_camel_underscore.symbols = private_fields
dotnet_naming_rule.private_fields_camel_underscore.style = underscore_camel
dotnet_naming_rule.private_fields_camel_underscore.severity = warning
dotnet_naming_symbols.private_fields.applicable_kinds = field
dotnet_naming_symbols.private_fields.applicable_accessibilities = private
dotnet_naming_style.underscore_camel.capitalization = camel_case
dotnet_naming_style.underscore_camel.required_prefix = _

# --- Tests ---
# Test names are sentences (Records_entries_in_order), which is the xunit convention and the reason
# a failing test reads like a statement of what broke. CA1707 forbids the underscores. The naming
# rule earns its keep in src/; in tests/ it would only make the failures harder to read.
[tests/**/*.cs]
dotnet_diagnostic.CA1707.severity = none
