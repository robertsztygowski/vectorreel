# mdreel — local configuration template
#
# RULE (DEVELOPMENT.md §6): every environment variable the app reads appears here
# with a placeholder. A new variable without its line in this file is a bug.
# Copy to .env (gitignored) and fill in real values. Never commit real values.
#
# GCP auth is Application Default Credentials — no key files, no variable needed:
#   gcloud auth application-default login

# --- GCP (dev) ---
GCP_PROJECT_ID=tensile-runway-442915-j6
GCP_REGION=europe-central2
VERTEX_LOCATION=europe-central2

# --- YouTube Data API (experiments only: licence verification, metadata) ---
# Read-only metadata. NEVER used for ingestion or to fetch bytes (CLAUDE.md rule 8):
# it exists solely to prove status.license == "creativeCommon" before a video may be
# published in the gallery or a post. Restricted key, youtube.googleapis.com only.
YOUTUBE_API_KEY=

# --- Media tooling (Stage A) ---
# Stage A is pure local compute: ffprobe reads the file's shape, ffmpeg extracts the frame
# timeline and the pauses in the narration. No cloud, no credentials. Leave these as the bare
# binary names to resolve them on PATH; set a full path if they live somewhere unusual.
FFMPEG_PATH=ffmpeg
FFPROBE_PATH=ffprobe

# --- Local dependencies (docker compose) ---
# The single shared Postgres instance is the source of truth for events, tenants, payments and the
# cost/ad-spend ledger (METRICS.md §6.2). Unset => the API uses in-memory stores (dev/test). Prod is
# the smallest Cloud SQL in europe-central2 (INFRA.md). POSTGRES_CONNECTION is read first, then
# ConnectionStrings:Postgres, then POSTGRES_CONNECTION_STRING.
POSTGRES_CONNECTION=
# POSTGRES_CONNECTION_STRING=Host=localhost;Port=5432;Database=vectorreel;Username=dev;Password=dev
# GCS_EMULATOR_HOST=http://localhost:4443

# --- Observability (OTel, TESTING.md §3) ---
# OTLP endpoint for traces + logs. Unset => no exporter is registered, nothing phones home
# (CLAUDE.md rule 10). The compose e2e profile points it at the local Aspire dashboard.
OTEL_EXPORTER_OTLP_ENDPOINT=

# --- CORS ---
# Comma-separated browser origins allowed to call the API (the web panel's origin, e.g.
# http://localhost:3000 in the compose e2e profile). Unset => no CORS headers at all.
CORS_ALLOWED_ORIGINS=

# --- Founder admin ---
# Comma-separated allowlist for /api/v1/admin/*.
# Empty/unset => 404 for everyone (fail closed).
Admin__Emails=

# --- Payments (Phase 4, Stripe) ---
# Real values live in Secret Manager in prod; never commit them. Unset => the API uses the fake
# payment gateway (deterministic checkout URL + test-signed webhooks) so the default test suite is
# hermetic. Prices/caps are hypotheses in BUSINESS_MODEL §6 (Pro hard-capped, Business metered).
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_PRO=
STRIPE_PRICE_BUSINESS=
# Starter (€99) is the dark on-ramp fallback — only reachable when SHOW_STARTER_PLAN=true.
STRIPE_PRICE_STARTER=
# Base URL Stripe redirects back to after checkout (success/cancel).
APP_BASE_URL=http://localhost
# Flip to true only if the launch shows the Pro step throttling checkout (BUSINESS_MODEL §6).
SHOW_STARTER_PLAN=false

# --- Web (Next.js, client-side) ---
# Base URL the web app posts first-party events / checkout requests to. Unset => the client stays
# offline (buffer + console only), so dev and tests need no backend.
NEXT_PUBLIC_API_BASE=
# Mirrors SHOW_STARTER_PLAN for the pricing page (keeps the €99 Starter dark by default).
NEXT_PUBLIC_SHOW_STARTER=false

# (POSTGRES_CONNECTION_STRING and GCS_EMULATOR_HOST above stay commented until wired.)
