# vectorreel — local configuration template
#
# RULE (DEVELOPMENT.md §6): every environment variable the app reads appears here
# with a placeholder. A new variable without its line in this file is a bug.
# Copy to .env (gitignored) and fill in real values. Never commit real values.
#
# GCP auth is Application Default Credentials — no key files, no variable needed:
#   gcloud auth application-default login

# --- GCP (dev) ---
GCP_PROJECT_ID=tensile-runway-442915-j6
GCP_REGION=europe-central2
VERTEX_LOCATION=europe-central2

# --- YouTube Data API (experiments only: licence verification, metadata) ---
# Read-only metadata. NEVER used for ingestion or to fetch bytes (CLAUDE.md rule 8):
# it exists solely to prove status.license == "creativeCommon" before a video may be
# published in the gallery or a post. Restricted key, youtube.googleapis.com only.
YOUTUBE_API_KEY=

# --- Media tooling (Stage A) ---
# Stage A is pure local compute: ffprobe reads the file's shape, ffmpeg extracts the frame
# timeline and the pauses in the narration. No cloud, no credentials. Leave these as the bare
# binary names to resolve them on PATH; set a full path if they live somewhere unusual.
FFMPEG_PATH=ffmpeg
FFPROBE_PATH=ffprobe

# --- Local dependencies (docker compose) ---
# POSTGRES_CONNECTION_STRING=Host=localhost;Port=5432;Database=vectorreel;Username=dev;Password=dev
# GCS_EMULATOR_HOST=http://localhost:4443

# (variables are commented out until the code that reads them exists)
